@@ -0,0 +1,38 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * IMA PKCS#11 keyring bridge header
+ */
+
+#ifndef _IMA_PKCS11_H
+#define _IMA_PKCS11_H
+
+#ifdef CONFIG_IMA_PKCS11_KEYRING
+
+int ima_pkcs11_keyring_add(struct key *keyring, const char *uri, size_t uri_len);
+int ima_pkcs11_sign(const char *uri, const void *data, size_t data_len,
+		     void *sig, size_t *sig_len);
+void ima_pkcs11_keyring_cleanup(struct key *keyring);
+
+#else
+
+static inline int ima_pkcs11_keyring_add(struct key *keyring, const char *uri, size_t uri_len)
+{
+	return -EOPNOTSUPP;
+}
+
+static inline int ima_pkcs11_sign(const char *uri, const void *data, size_t data_len,
+				   void *sig, size_t *sig_len)
+{
+	return -EOPNOTSUPP;
+}
+
+static inline void ima_pkcs11_keyring_cleanup(struct key *keyring)
+{
+}
+
+#endif /* CONFIG_IMA_PKCS11_KEYRING */
+
+#define ima_pkcs11_keyring_is_available() \
+	IS_ENABLED(CONFIG_IMA_PKCS11_KEYRING)
+
+#endif /* _IMA_PKCS11_H */
