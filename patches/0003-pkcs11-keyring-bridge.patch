 security/integrity/ima/Makefile     |   1 +
 security/integrity/ima/ima_pkcs11.c | 142 +++++++++++++++++++++++++++
 security/integrity/ima/ima_pkcs11.h |  38 ++++++++
 security/integrity/ima/ima_main.c   |   8 ++
 5 files changed, 201 insertions(+)

