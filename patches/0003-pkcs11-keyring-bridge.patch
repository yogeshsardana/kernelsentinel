index 1234567..abcdef0 100644
--- a/security/integrity/ima/Kconfig
+++ b/security/integrity/ima/Kconfig
@@ -330,3 +330,15 @@ config IMA_DISABLE_HTABLE
 	depends on IMA
 	default n
 	help
+
+config IMA_PKCS11_KEYRING
+	bool "IMA PKCS#11 keyring bridge"
+	depends on IMA && PKCS11
+	default n
